# =========================================================================
# CLOUDCART GLOBAL ENVIRONMENT VARIABLES
# =========================================================================

# Database Configuration (PostgreSQL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=cloudcart_main

# JWT Authentication Secret Key (Used by User and Order Service)
# In production, change this to a long, complex, cryptographically secure string
JWT_SECRET=cloudcart_jwt_secret_key_2026

# =========================================================================
# INDIVIDUAL SERVICE OVERRIDES (Optional for local running outside Docker)
# =========================================================================

# Database Ports
DB_PORT=5432
DB_HOST=postgres

# Frontend Client Service Routes (Only needed if running outside default ports)
# VITE_USER_SERVICE_URL=http://localhost:5001
# VITE_PRODUCT_SERVICE_URL=http://localhost:5002
# VITE_ORDER_SERVICE_URL=http://localhost:5003
